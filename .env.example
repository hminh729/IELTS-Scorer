# ====================================
# IELTS Scorer — Docker Environment
# Copy this to .env and fill in values
# ====================================

# Google Gemini API Key (required for LLM feedback)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret for authentication (generate a random string)
JWT_SECRET=change_me_to_a_random_64_char_string

# Google OAuth (optional — leave empty to disable Google login)
GG_Client_Id=
GG_Client_Secret=
